# Phosche 项目构建脚本
# 提供开发、构建、测试、清理等常用命令
# 用法：make <target>
#   make build          # 生产构建（含前端）
#   make run            # 开发模式运行（需 OpenSearch 已启动）
#   make test           # 运行全部测试（含集成测试，需 Docker）

.PHONY: build build-frontend docker-build clean test test-race run

# -----------------------------------------------------------
# 生产构建：编译 Go 二进制（开发模式入口 cmd/phosche/）
# 产物：当前目录下的 phosche 可执行文件
# 注意：生产部署推荐使用 docker-build（嵌入前端 SPA）
# -----------------------------------------------------------
build:
	go build -o phosche ./cmd/phosche/

# -----------------------------------------------------------
# 前端构建：安装依赖 + 构建前端静态资源
# 产物：web/dist/ 目录，供 go:embed 嵌入或 Vite 开发服务器使用
# 在 Docker 多阶段构建中会自动执行此步骤
# -----------------------------------------------------------
build-frontend:
	cd web && npm ci && npm run build

# -----------------------------------------------------------
# Docker 多阶段构建：自动完成前端 + Go 编译
# 产物：phosche 镜像（包含内嵌 SPA 的单二进制）
# 推送前请确保版本 tag 已打好
# -----------------------------------------------------------
docker-build:
	docker build -t phosche .

# -----------------------------------------------------------
# 运行全部 Go 单元测试（含集成测试）
# 集成测试使用 testcontainers-go，会自动启动 OpenSearch 容器
# 首次运行会拉取 opensearch:2.19.5 镜像，请确保 Docker 已启动
# -----------------------------------------------------------
test:
	go test ./...

# -----------------------------------------------------------
# 带竞态检测的测试（检测并发数据访问问题）
# 推荐在 CI 中使用，可发现潜在的并发 bug
# 运行速度比普通测试慢，且对内存消耗更大
# -----------------------------------------------------------
test-race:
	go test -race ./...

# -----------------------------------------------------------
# 清理构建产物
# 删除编译的二进制文件和前端构建输出
# -----------------------------------------------------------
clean:
	rm -f phosche
	rm -rf web/dist

# -----------------------------------------------------------
# 开发模式运行（仅后端）
# 需要 OpenSearch 已启动并可访问
# 配置文件默认读取 config.yaml
# 前端需另开终端运行：cd web && npm run dev
# -----------------------------------------------------------
run:
	go run ./cmd/phosche/ -config config.yaml
